# Worker (data-plane) secrets. Copy to `.env.worker` and `chmod 600`.
# Outbound-only process: Supabase + RTP + LLM provider. Holds the service-role
# key and the LLM keys — never expose this file or these values on any network.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Required only because a shared lib constructs the public client at import time;
# the worker itself writes with the service-role key below.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — full DB access, bypasses RLS. The worker's real credential.
SUPABASE_SECRET_KEY=

# --- LLM (OpenAI is the default provider; at least one key is required) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# Optional deploy-wide default + model override (else per-job → env → built-in):
# LLM_PROVIDER=openai
# LLM_MODEL=

# --- Worker tuning (optional) ---
# WORKER_POLL_INTERVAL_MS=5000
